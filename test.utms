// UTMS Compiler Test Suite
// Full language feature verification

sc.true

// -------------------------------------------------------------------
// 1. Sections
// -------------------------------------------------------------------
sect.config
    u64 version = 1;
    u64 debug = 1;
    string app_name = "UTMS Test";
    u64 locate buffer = mloc(1024);
EOS

sect.colors
    u32 red = 0xFF0000;
    u32 green = 0x00FF00;
    u32 blue = 0x0000FF;
    u32 white = 0xFFFFFF;
EOS

sect.stats
    u64 calls = 0;
    u64 errors = 0;
    u64 total = 0;
EOS

// -------------------------------------------------------------------
// 2. Global variables
// -------------------------------------------------------------------
u64 global_counter = 0;
string global_name = "Global";
u64 locate global_ptr = mloc(256);

// -------------------------------------------------------------------
// 3. Functions
// -------------------------------------------------------------------

fn factorial(u64 n) {
    stats:calls = stats:calls + 1;
    
    if (n <= 1) {
        return u64 1;
    } else {
        u64 result = n * factorial(n - 1);
        return u64 result;
    }
}

fn get_stats() {
    return u64 stats:calls, u64 stats:errors, u64 stats:total;
}

fn greet(string name) {
    printf("Hello, %v!\n", name);
    stats:total = stats:total + 1;
}

fn calculate(u64 a, u64 b, string op) {
    u64 result;
    
    if (op == "add") {
        result = a + b;
    } else if (op == "sub") {
        result = a - b;
    } else if (op == "mul") {
        result = a * b;
    } else if (op == "div") {
        if (b != 0) {
            result = a / b;
        } else {
            printf("Error: division by zero!\n");
            stats:errors = stats:errors + 1;
            return u64 0;
        }
    } else {
        printf("Unknown operation: %v\n", op);
        stats:errors = stats:errors + 1;
        return u64 0;
    }
    
    stats:total = stats:total + 1;
    return u64 result;
}

fn use_pointer(u64 locate ptr, u64 size) {
    for (u64 i = 0; i < size; i = i + 1) {
        ::nasm::{
            mov rax, [i]
            mov rbx, [ptr]
            add rbx, rax
            mov byte [rbx], 0xAA
        }
    }
}

// -------------------------------------------------------------------
// 4. Main
// -------------------------------------------------------------------
fn main() {
    printf("\n=== UTMS Language Test ===\n");
    printf("App: %v, Version: %v\n", config:app_name, config:version);
    printf("Debug mode: %v\n", config:debug);
    
    // ---------------------------------------------------------------
    // 5. Variables and types
    // ---------------------------------------------------------------
    printf("\n--- Variable Types ---\n");
    
    u8 b = 255;
    u16 w = 65535;
    u32 d = 4294967295;
    u64 q = 18446744073709551615;
    
    i8 sb = -128;
    i16 sw = -32768;
    i32 sd = -2147483648;
    i64 sq = -9223372036854775808;
    
    string s = "Hello, World!";
    u64 locate p = mloc(512);
    
    printf("u8: %v, u16: %v, u32: %v, u64: %v\n", b, w, d, q);
    printf("i8: %v, i16: %v, i32: %v, i64: %v\n", sb, sw, sd, sq);
    printf("string: %v\n", s);
    printf("pointer: 0x%v\n", p);
    
    // ---------------------------------------------------------------
    // 6. Arithmetic
    // ---------------------------------------------------------------
    printf("\n--- Arithmetic ---\n");
    
    u64 a = 42;
    u64 b2 = 10;
    
    u64 sum = a + b2;
    u64 diff = a - b2;
    u64 prod = a * b2;
    u64 quot = a / b2;
    u64 rem = a % b2;
    
    printf("%v + %v = %v\n", a, b2, sum);
    printf("%v - %v = %v\n", a, b2, diff);
    printf("%v * %v = %v\n", a, b2, prod);
    printf("%v / %v = %v\n", a, b2, quot);
    printf("%v %% %v = %v\n", a, b2, rem);
    
    // ---------------------------------------------------------------
    // 7. Comparison
    // ---------------------------------------------------------------
    printf("\n--- Comparison ---\n");
    
    u64 x = 10;
    u64 y = 20;
    u64 z = 10;
    
    printf("%v == %v: %v\n", x, z, x == z);
    printf("%v != %v: %v\n", x, y, x != y);
    printf("%v < %v: %v\n", x, y, x < y);
    printf("%v > %v: %v\n", x, y, x > y);
    printf("%v <= %v: %v\n", x, z, x <= z);
    printf("%v >= %v: %v\n", y, x, y >= x);
    
    // ---------------------------------------------------------------
    // 8. Logical operators
    // ---------------------------------------------------------------
    printf("\n--- Logic ---\n");
    
    u64 t = 1;
    u64 f = 0;
    
    printf("true && true: %v\n", t && t);
    printf("true && false: %v\n", t && f);
    printf("true || false: %v\n", t || f);
    printf("false || false: %v\n", f || f);
    printf("!true: %v\n", !t);
    printf("!false: %v\n", !f);
    
    // ---------------------------------------------------------------
    // 9. Conditionals
    // ---------------------------------------------------------------
    printf("\n--- Conditionals ---\n");
    
    u64 value = 42;
    
    if (value > 100) {
        printf("value > 100\n");
    } else if (value > 50) {
        printf("value > 50\n");
    } else if (value > 0) {
        printf("value > 0\n");
    } else {
        printf("value <= 0\n");
    }
    
    u64 abs_val;
    if (value >= 0) {
        abs_val = value;
    } else {
        abs_val = -value;
    }
    printf("abs(%v) = %v\n", value, abs_val);
    
    // ---------------------------------------------------------------
    // 10. Loops
    // ---------------------------------------------------------------
    printf("\n--- Loops ---\n");
    
    printf("for: ");
    for (u64 i = 0; i < 5; i = i + 1) {
        printf("%v ", i);
    }
    printf("\n");
    
    printf("while: ");
    u64 j = 0;
    while (j < 5) {
        printf("%v ", j);
        j = j + 1;
    }
    printf("\n");
    
    printf("nested:\n");
    for (u64 i = 0; i < 3; i = i + 1) {
        printf("  %v: ", i);
        for (u64 k = 0; k < 3; k = k + 1) {
            printf("%v ", i * k);
        }
        printf("\n");
    }
    
    // ---------------------------------------------------------------
    // 11. Function calls
    // ---------------------------------------------------------------
    printf("\n--- Function Calls ---\n");
    
    u64 fact5 = factorial(5);
    printf("factorial(5) = %v\n", fact5);
    
    u64 calc1 = calculate(10, 3, "add");
    u64 calc2 = calculate(10, 3, "sub");
    u64 calc3 = calculate(10, 3, "mul");
    u64 calc4 = calculate(10, 3, "div");
    
    printf("10 + 3 = %v\n", calc1);
    printf("10 - 3 = %v\n", calc2);
    printf("10 * 3 = %v\n", calc3);
    printf("10 / 3 = %v\n", calc4);
    
    u64 calc5 = calculate(10, 0, "div");
    printf("10 / 0 = %v (error case)\n", calc5);
    
    greet("World");
    greet("UTMS");
    
    // ---------------------------------------------------------------
    // 12. Multiple return values
    // ---------------------------------------------------------------
    printf("\n--- Multiple Returns ---\n");
    
    u64 calls, errors, total;
    calls, errors, total = get_stats();
    
    printf("Stats - calls: %v, errors: %v, total: %v\n", 
           calls, errors, total);
    
    u64 a1, a2, a3;
    a1 = a2 = a3 = 99;
    printf("Chain assignment: %v %v %v\n", a1, a2, a3);
    
    // ---------------------------------------------------------------
    // 13. Section access
    // ---------------------------------------------------------------
    printf("\n--- Sections ---\n");
    
    printf("Config version: %v\n", config:version);
    printf("Colors red: 0x%v\n", colors:red);
    printf("Colors green: 0x%v\n", colors:green);
    printf("Colors blue: 0x%v\n", colors:blue);
    
    config:debug = 0;
    stats:total = stats:total + 10;
    
    printf("Debug after change: %v\n", config:debug);
    printf("Total after change: %v\n", stats:total);
    
    // ---------------------------------------------------------------
    // 14. Memory management
    // ---------------------------------------------------------------
    printf("\n--- Memory Management ---\n");
    
    u64 locate buf1 = mloc(128);
    printf("buf1 at: 0x%v\n", buf1);
    
    u64 locate buf2 = mloc(buf1, 256);
    printf("buf2 at: 0x%v\n", buf2);
    
    u64 locate buf3 = mloc(buf1, 512, 16);
    printf("buf3 at: 0x%v\n", buf3);
    
    use_pointer(buf3, 64);
    
    mfree(buf1);
    mfree(buf2);
    mfree(buf3);
    printf("Memory freed\n");
    
    // ---------------------------------------------------------------
    // 15. Inline assembly
    // ---------------------------------------------------------------
    printf("\n--- Assembly ---\n");
    
    u64 asm_result = 0;
    u64 asm_x = 10;
    u64 asm_y = 20;
    
    ::nasm::{
        mov rax, [asm_x]
        add rax, [asm_y]
        mov [asm_result], rax
    }
    
    printf("ASM %v + %v = %v\n", asm_x, asm_y, asm_result);
    
    ::nasm::{
        mov rax, 0xDEADBEEF
        mov rbx, 0xCAFEBABE
        xor rax, rbx
    }
    
    // ---------------------------------------------------------------
    // 16. User input (OS mode only)
    // ---------------------------------------------------------------
    printf("\n--- Input Test ---\n");
    
    string user_name;
    printf("Enter your name: ");
    input(user_name);
    printf("Hello, %v!\n", user_name);
    
    string answer;
    input("Are you enjoying UTMS? (yes/no): ", string answer);
    
    if (answer == "yes" || answer == "y" || answer == "Yes") {
        printf("Great!\n");
    } else {
        printf("Oh no!\n");
    }
    
    // ---------------------------------------------------------------
    // 17. Complex expressions
    // ---------------------------------------------------------------
    printf("\n--- Complex Expressions ---\n");
    
    u64 complex = (10 + 20) * (30 - 10) / 5 + 100 % 3;
    printf("(10+20)*(30-10)/5 + 100%%3 = %v\n", complex);
    
    u64 logical = (10 > 5) && (20 < 30) || !(40 == 50);
    printf("(10>5) && (20<30) || !(40==50) = %v\n", logical);
    
    // ---------------------------------------------------------------
    // 18. Final statistics
    // ---------------------------------------------------------------
    printf("\n--- Final Stats ---\n");
    
    u64 f_calls, f_errors, f_total;
    f_calls, f_errors, f_total = get_stats();
    
    printf("Final stats - calls: %v, errors: %v, total: %v\n",
           f_calls, f_errors, f_total);
    
    printf("\n=== Test Complete ===\n");
    
    // ---------------------------------------------------------------
    // 19. jmpto (commented out – requires external module)
    // ---------------------------------------------------------------
    /*
    jmpto "math.utms" {
        u64 x = 42;
        u64 y = 24;
    }
    */
}

// -------------------------------------------------------------------
// 20. Additional functions
// -------------------------------------------------------------------

fn fibonacci(u64 n) {
    stats:calls = stats:calls + 1;
    
    if (n <= 1) {
        return u64 n;
    } else {
        u64 a = fibonacci(n - 1);
        u64 b = fibonacci(n - 2);
        return u64 a + b;
    }
}

fn process_values(u64 a, u64 b, u64 c, u64 d, string label) {
    printf("%v: %v %v %v %v\n", label, a, b, c, d);
    stats:total = stats:total + 1;
    return u64 a + b + c + d;
}
